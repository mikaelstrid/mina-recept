# Auth.js
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Resend (magic link email)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=noreply@yourdomain.com

# Storage: "local" uses the data/ directory; "azure" uses Azure services
STORAGE_PROVIDER=local

# Azure Storage (production only)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_TABLE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER_NAME=recipe-images

# Azure AI Foundry (Phase 2)
AZURE_AI_ENDPOINT=
AZURE_AI_API_KEY=
AZURE_AI_DEPLOYMENT_NAME=
ENABLE_AI_FEATURES=false
